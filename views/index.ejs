<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Job Hunter Dashboard</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
    header { background: #1e293b; padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #334155; }
    header h1 { font-size: 1.25rem; font-weight: 700; color: #f8fafc; }
    header nav a { color: #94a3b8; text-decoration: none; margin-left: 20px; font-size: 0.875rem; }
    header nav a:hover { color: #f8fafc; }
    .container { max-width: 1400px; margin: 0 auto; padding: 24px; }
    .filters { background: #1e293b; border-radius: 8px; padding: 16px; margin-bottom: 20px; display: flex; flex-wrap: wrap; gap: 12px; align-items: center; }
    .filter-tabs { display: flex; gap: 6px; flex-wrap: wrap; }
    .tab { padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 500; text-decoration: none; border: 1px solid #334155; color: #94a3b8; transition: all 0.15s; }
    .tab:hover { background: #334155; color: #f8fafc; }
    .tab.active { background: #3b82f6; border-color: #3b82f6; color: #fff; }
    .search-form { display: flex; gap: 8px; flex: 1; min-width: 280px; }
    .search-form input { flex: 1; background: #0f172a; border: 1px solid #334155; border-radius: 6px; padding: 8px 12px; color: #e2e8f0; font-size: 0.875rem; }
    .search-form input:focus { outline: none; border-color: #3b82f6; }
    .search-form button { background: #3b82f6; border: none; border-radius: 6px; padding: 8px 16px; color: white; cursor: pointer; font-size: 0.875rem; }
    .search-form button:hover { background: #2563eb; }
    .stats-bar { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .stat-card { background: #1e293b; border-radius: 8px; padding: 12px 20px; flex: 1; min-width: 120px; text-align: center; }
    .stat-card .value { font-size: 1.5rem; font-weight: 700; }
    .stat-card .label { font-size: 0.75rem; color: #64748b; margin-top: 2px; }
    .table-wrap { background: #1e293b; border-radius: 8px; overflow: hidden; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    th { background: #0f172a; padding: 10px 14px; text-align: left; font-weight: 600; color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
    td { padding: 10px 14px; border-top: 1px solid #1a2740; vertical-align: middle; }
    tr:hover td { background: #162032; }
    .status-badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; }
    .source-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; background: #0f172a; color: #94a3b8; border: 1px solid #334155; }
    a.job-link { color: #60a5fa; text-decoration: none; font-weight: 500; }
    a.job-link:hover { text-decoration: underline; }
    .salary { color: #4ade80; font-weight: 500; }
    .tag-easy { background: #f59e0b22; color: #f59e0b; border: 1px solid #f59e0b44; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; margin-left: 6px; }
    .tag-yc { background: #f9731622; color: #f97316; border: 1px solid #f9731644; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; margin-left: 4px; }
    .status-select { background: #0f172a; border: 1px solid #334155; border-radius: 4px; padding: 4px 8px; color: #e2e8f0; font-size: 0.8rem; cursor: pointer; }
    .pagination { display: flex; justify-content: center; gap: 8px; margin-top: 20px; }
    .page-btn { background: #1e293b; border: 1px solid #334155; border-radius: 6px; padding: 8px 14px; color: #94a3b8; text-decoration: none; font-size: 0.875rem; }
    .page-btn:hover, .page-btn.active { background: #3b82f6; border-color: #3b82f6; color: #fff; }
    .empty { text-align: center; padding: 60px; color: #64748b; }
  </style>
</head>
<body>
  <header>
    <h1>🎯 Job Hunter</h1>
    <nav>
      <a href="/">Dashboard</a>
      <a href="/stats">Stats</a>
    </nav>
  </header>

  <div class="container">
    <div class="filters">
      <div class="filter-tabs">
        <a href="/?status=all&search=<%= filters.search %>" class="tab <%= filters.status === 'all' ? 'active' : '' %>">All (<%= total %>)</a>
        <% statuses.forEach(function(s) { %>
          <a href="/?status=<%= s %>&search=<%= filters.search %>"
             class="tab <%= filters.status === s ? 'active' : '' %>"
             style="<%= filters.status === s ? 'background:' + statusColors[s] + ';border-color:' + statusColors[s] : '' %>">
            <%= s.charAt(0).toUpperCase() + s.slice(1) %>
          </a>
        <% }); %>
      </div>
      <form class="search-form" method="get">
        <input type="hidden" name="status" value="<%= filters.status %>">
        <input type="text" name="search" placeholder="Search by title or company..." value="<%= filters.search %>">
        <button type="submit">Search</button>
      </form>
    </div>

    <div class="table-wrap">
      <% if (jobs.length === 0) { %>
        <div class="empty">No jobs found. Run the scraper to fetch new listings.</div>
      <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Company</th>
            <th>Salary</th>
            <th>Location</th>
            <th>Source</th>
            <th>Status</th>
            <th>Applied</th>
            <th>Scraped</th>
            <th>Link</th>
          </tr>
        </thead>
        <tbody>
          <% jobs.forEach(function(job) { %>
          <tr>
            <td>
              <%= job.title %>
              <% if (job.easyApply) { %><span class="tag-easy">⚡ Easy</span><% } %>
              <% if (job.ycBatch) { %><span class="tag-yc">🚀 YC <%= job.ycBatch %></span><% } %>
            </td>
            <td><strong><%= job.company %></strong></td>
            <td class="salary"><%= job.salary || 'N/A' %></td>
            <td><%= job.location || '–' %></td>
            <td><span class="source-badge"><%= job.source.toUpperCase() %></span></td>
            <td>
              <select class="status-select" onchange="updateStatus(<%= job.id %>, this.value)">
                <% ['new','saved','applied','interview','rejected','offer'].forEach(function(s) { %>
                  <option value="<%= s %>" <%= job.status === s ? 'selected' : '' %>
                    style="<%= job.status === s ? 'color: inherit' : '' %>">
                    <%= s.charAt(0).toUpperCase() + s.slice(1) %>
                  </option>
                <% }); %>
              </select>
            </td>
            <td><%= job.appliedAt ? new Date(job.appliedAt).toLocaleDateString('en-IN') : '–' %></td>
            <td><%= new Date(job.createdAt).toLocaleDateString('en-IN') %></td>
            <td><a class="job-link" href="<%= job.url %>" target="_blank" rel="noopener">Apply →</a></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>
    </div>

    <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (currentPage > 1) { %>
        <a class="page-btn" href="/?status=<%= filters.status %>&search=<%= filters.search %>&page=<%= currentPage - 1 %>">← Prev</a>
      <% } %>
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a class="page-btn <%= i === currentPage ? 'active' : '' %>"
           href="/?status=<%= filters.status %>&search=<%= filters.search %>&page=<%= i %>"><%= i %></a>
      <% } %>
      <% if (currentPage < totalPages) { %>
        <a class="page-btn" href="/?status=<%= filters.status %>&search=<%= filters.search %>&page=<%= currentPage + 1 %>">Next →</a>
      <% } %>
    </div>
    <% } %>
  </div>

  <script>
    async function updateStatus(jobId, status) {
      try {
        const res = await fetch('/update-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ jobId, status })
        });
        if (!res.ok) {
          const err = await res.json();
          alert('Error: ' + err.error);
        }
      } catch (e) {
        alert('Failed to update status');
      }
    }
  </script>
</body>
</html>
