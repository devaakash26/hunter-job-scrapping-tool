<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Job Hunter</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #060912;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    /* Background blobs */
    .blob {
      position: fixed; pointer-events: none; border-radius: 50%;
      filter: blur(100px); z-index: 0;
    }
    .b1 { width: 600px; height: 500px; top: -200px; left: -100px; background: rgba(99,102,241,0.12); }
    .b2 { width: 500px; height: 400px; bottom: -150px; right: -100px; background: rgba(139,92,246,0.09); }

    /* Card */
    .card {
      position: relative; z-index: 10;
      width: 100%; max-width: 400px;
      background: rgba(255,255,255,0.03);
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 24px;
      padding: 44px 40px 40px;
      box-shadow: 0 32px 64px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.04) inset;
      margin: 20px;
    }

    /* Logo */
    .logo-wrap { text-align: center; margin-bottom: 36px; }
    .logo-icon {
      width: 56px; height: 56px; border-radius: 16px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 26px; margin-bottom: 16px;
      box-shadow: 0 8px 24px rgba(99,102,241,0.4);
    }
    .logo-title {
      font-size: 20px; font-weight: 900; color: #fff;
      letter-spacing: -0.03em; margin-bottom: 4px;
    }
    .logo-sub { font-size: 12px; color: rgba(255,255,255,0.3); font-weight: 400; }

    /* Error */
    .error-box {
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 10px;
      padding: 10px 14px;
      color: #fca5a5;
      font-size: 12px;
      font-weight: 500;
      margin-bottom: 20px;
      display: flex; align-items: center; gap: 8px;
    }

    /* Form */
    .field { margin-bottom: 16px; }
    .field label {
      display: block;
      font-size: 10px; font-weight: 700;
      color: rgba(255,255,255,0.3);
      text-transform: uppercase; letter-spacing: 0.1em;
      margin-bottom: 7px;
    }
    .field input {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 11px;
      padding: 12px 14px;
      color: #fff;
      font-size: 14px;
      font-family: inherit;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .field input:focus {
      border-color: rgba(99,102,241,0.5);
      box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
    }
    .field input::placeholder { color: rgba(255,255,255,0.18); }

    /* Submit */
    .btn {
      width: 100%; margin-top: 8px;
      background: linear-gradient(135deg, #6366f1, #7c3aed);
      border: none; border-radius: 11px;
      padding: 13px; color: #fff;
      font-size: 14px; font-weight: 700;
      font-family: inherit; cursor: pointer;
      box-shadow: 0 4px 16px rgba(99,102,241,0.35);
      transition: opacity 0.15s, transform 0.1s;
    }
    .btn:hover { opacity: 0.9; }
    .btn:active { transform: scale(0.99); }

    .footer { text-align: center; margin-top: 24px; font-size: 10px; color: rgba(255,255,255,0.12); }
  </style>
</head>
<body>
  <div class="blob b1"></div>
  <div class="blob b2"></div>

  <div class="card">
    <div class="logo-wrap">
      <div class="logo-icon">🎯</div>
      <div class="logo-title">Job Hunter</div>
      <div class="logo-sub">Personal job tracking dashboard</div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="error-box">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/login">
      <% if (typeof next !== 'undefined' && next) { %>
        <input type="hidden" name="next" value="<%= next %>">
      <% } %>
      <div class="field">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="Enter username" autocomplete="username" required>
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter password" autocomplete="current-password" required>
      </div>
      <button type="submit" class="btn">Sign in →</button>
    </form>

    <div class="footer">Job Hunter v2.0 · Personal use only</div>
  </div>
</body>
</html>
