<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stats — Job Hunter</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f0f2f5; --surface: #ffffff; --border: #e5e7eb; --border2: #d1d5db;
      --text: #111827; --muted: #6b7280; --faint: #9ca3af;
      --accent: #4f46e5; --sidebar-w: 256px;
    }
    html, body { height: 100%; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; }

    /* ── Sidebar (shared) ── */
    .sidebar {
      position: fixed; top: 0; left: 0; bottom: 0; width: var(--sidebar-w);
      background: var(--surface); border-right: 1px solid var(--border);
      display: flex; flex-direction: column; z-index: 200;
      transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
    }
    .sidebar-logo { padding: 22px 20px 18px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--border); }
    .logo-mark { width: 34px; height: 34px; border-radius: 10px; flex-shrink: 0; background: linear-gradient(135deg,#6366f1,#8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 16px; box-shadow: 0 4px 10px rgba(99,102,241,0.3); }
    .logo-text { font-size: 14px; font-weight: 800; color: var(--text); letter-spacing: -0.02em; line-height: 1.2; }
    .logo-sub { font-size: 10px; color: var(--faint); font-weight: 400; }
    .sidebar-nav { flex: 1; padding: 12px 10px; overflow-y: auto; }
    .nav-section-label { font-size: 9px; font-weight: 700; color: var(--faint); text-transform: uppercase; letter-spacing: 0.1em; padding: 12px 10px 6px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 10px; font-size: 13px; font-weight: 500; color: var(--muted); text-decoration: none; margin-bottom: 2px; transition: background 0.15s, color 0.15s; }
    .nav-item:hover { background: #f9fafb; color: var(--text); }
    .nav-item.active { background: rgba(79,70,229,0.08); color: var(--accent); font-weight: 600; }
    .nav-icon { width: 18px; text-align: center; font-size: 14px; opacity: 0.6; flex-shrink: 0; }
    .nav-badge { margin-left: auto; font-size: 10px; font-weight: 700; padding: 1px 7px; border-radius: 99px; background: rgba(79,70,229,0.1); color: var(--accent); }
    .sidebar-footer { padding: 12px 10px 16px; border-top: 1px solid var(--border); }

    /* ── Main ── */
    .main { margin-left: var(--sidebar-w); min-height: 100vh; display: flex; flex-direction: column; }
    .topbar { position: sticky; top: 0; z-index: 100; background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 28px; height: 60px; display: flex; align-items: center; gap: 12px; }
    .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 6px; border-radius: 8px; color: var(--muted); }
    .topbar-title { font-size: 15px; font-weight: 700; color: var(--text); }
    .btn-outline { display: flex; align-items: center; gap: 6px; padding: 7px 14px; border-radius: 9px; font-size: 12px; font-weight: 600; font-family: inherit; cursor: pointer; border: 1px solid var(--border); background: var(--surface); color: var(--muted); text-decoration: none; transition: all 0.15s; }
    .btn-outline:hover { border-color: var(--border2); color: var(--text); }
    .content { padding: 28px 28px 60px; }

    /* ── KPI cards ── */
    .kpi-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 14px; margin-bottom: 24px; }
    .kpi-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: 16px;
      padding: 20px 22px; position: relative; overflow: hidden;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .kpi-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
    .kpi-icon { font-size: 22px; margin-bottom: 12px; }
    .kpi-value { font-size: 30px; font-weight: 900; color: var(--text); letter-spacing: -0.03em; line-height: 1; margin-bottom: 4px; }
    .kpi-label { font-size: 10px; font-weight: 700; color: var(--faint); text-transform: uppercase; letter-spacing: 0.08em; }
    .kpi-sub { font-size: 11px; color: var(--muted); margin-top: 6px; }
    .kpi-accent-bar { position: absolute; bottom: 0; left: 0; right: 0; height: 3px; border-radius: 0 0 16px 16px; }

    /* ── Chart grid ── */
    .charts-row { display: grid; gap: 16px; margin-bottom: 16px; }
    .charts-row-2 { grid-template-columns: 1fr 1fr; }
    .charts-row-3 { grid-template-columns: 3fr 2fr; }
    .chart-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: 16px;
      padding: 24px; overflow: hidden;
    }
    .chart-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20px; }
    .chart-title { font-size: 14px; font-weight: 700; color: var(--text); }
    .chart-sub { font-size: 11px; color: var(--faint); margin-top: 2px; }
    .chart-badge { font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 99px; background: rgba(79,70,229,0.08); color: var(--accent); }

    /* Funnel rows (custom pure CSS funnel) */
    .funnel-wrap { display: flex; flex-direction: column; gap: 6px; }
    .funnel-row { display: flex; align-items: center; gap: 12px; }
    .funnel-label { font-size: 11px; font-weight: 600; color: var(--muted); width: 70px; flex-shrink: 0; text-align: right; }
    .funnel-track { flex: 1; height: 28px; background: #f3f4f6; border-radius: 6px; overflow: hidden; position: relative; }
    .funnel-fill { height: 100%; border-radius: 6px; display: flex; align-items: center; justify-content: flex-end; padding-right: 10px; font-size: 11px; font-weight: 700; color: #fff; transition: width 1s cubic-bezier(0.22,1,0.36,1); min-width: 36px; }
    .funnel-count { font-size: 11px; font-weight: 700; color: var(--text); width: 36px; flex-shrink: 0; }

    /* Conversion rates */
    .conv-row { display: flex; align-items: center; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
    .conv-chip { font-size: 10px; padding: 3px 9px; border-radius: 99px; background: #f3f4f6; color: var(--muted); font-weight: 600; }
    .conv-chip.good { background: rgba(5,150,105,0.08); color: #059669; }

    /* Sidebar overlay */
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.35); z-index: 199; backdrop-filter: blur(2px); }

    @media (max-width: 768px) {
      .sidebar { transform: translateX(calc(-1 * var(--sidebar-w))); }
      .sidebar.open { transform: translateX(0); }
      .main { margin-left: 0; }
      .hamburger { display: flex; }
      .content { padding: 16px 16px 60px; }
      .topbar { padding: 0 16px; }
      .charts-row-2, .charts-row-3 { grid-template-columns: 1fr; }
      .sidebar-overlay.open { display: block; }
    }
  </style>
</head>
<body>

<div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-mark">🎯</div>
    <div>
      <div class="logo-text">Job Hunter</div>
      <div class="logo-sub">personal dashboard</div>
    </div>
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section-label">Browse</div>
    <%
      const NAV = [
        { key:'all',       label:'All Jobs',   icon:'🏠', href:'/?status=all' },
        { key:'new',       label:'New',         icon:'✨', href:'/?status=new' },
        { key:'saved',     label:'Saved',       icon:'🔖', href:'/?status=saved' },
        { key:'applied',   label:'Applied',     icon:'📤', href:'/?status=applied' },
        { key:'interview', label:'Interviews',  icon:'🤝', href:'/?status=interview' },
        { key:'offer',     label:'Offers',      icon:'🏆', href:'/?status=offer' },
        { key:'rejected',  label:'Rejected',    icon:'❌', href:'/?status=rejected' },
      ];
      NAV.forEach(function(n) {
        const cnt = n.key === 'all' ? stats.total : (stats.byStatus[n.key] || 0);
    %>
    <a href="<%= n.href %>" class="nav-item">
      <span class="nav-icon"><%= n.icon %></span>
      <%= n.label %>
      <% if (cnt > 0) { %><span class="nav-badge"><%= cnt %></span><% } %>
    </a>
    <% }); %>
    <div class="nav-section-label" style="margin-top:8px;">Manage</div>
    <a href="/stats" class="nav-item active">
      <span class="nav-icon">📊</span> Stats
    </a>
  </nav>
  <div class="sidebar-footer">
    <a href="/logout" class="nav-item" style="color:#ef4444;">
      <span class="nav-icon">🚪</span> Logout
    </a>
  </div>
</aside>

<!-- ══ MAIN ══ -->
<div class="main">
  <div class="topbar">
    <button class="hamburger" onclick="openSidebar()">
      <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <span class="topbar-title">Analytics</span>
    <div style="margin-left:auto;">
      <a href="/" class="btn-outline">← Dashboard</a>
    </div>
  </div>

  <div class="content">

    <!-- KPI cards -->
    <div class="kpi-row">
      <%
        const kpis = [
          { icon:'🗂️', value: stats.total,                     label:'Total Scraped',  sub:'all time',                  color:'#6366f1' },
          { icon:'📤', value: stats.byStatus.applied  || 0,    label:'Applied',        sub:'jobs submitted',            color:'#f59e0b' },
          { icon:'🤝', value: stats.byStatus.interview|| 0,    label:'Interviews',     sub:'responses received',        color:'#10b981' },
          { icon:'🏆', value: stats.byStatus.offer    || 0,    label:'Offers',         sub:'congratulations!',          color:'#22c55e' },
          { icon:'📈', value: stats.responseRate + '%',        label:'Response Rate',  sub:'interviews ÷ applied',      color:'#3b82f6' },
          { icon:'📅', value: stats.thisWeek,                  label:'This Week',      sub: (stats.thisWeek > stats.lastWeek ? '▲' : (stats.thisWeek < stats.lastWeek ? '▼' : '–')) + ' vs last week (' + stats.lastWeek + ')', color: stats.thisWeek >= stats.lastWeek ? '#059669' : '#ef4444' },
        ];
      %>
      <% kpis.forEach(function(k) { %>
      <div class="kpi-card">
        <div class="kpi-icon"><%= k.icon %></div>
        <div class="kpi-value" style="color:<%= k.color %>"><%= k.value %></div>
        <div class="kpi-label"><%= k.label %></div>
        <div class="kpi-sub"><%= k.sub %></div>
        <div class="kpi-accent-bar" style="background:<%= k.color %>22;"></div>
      </div>
      <% }); %>
    </div>

    <!-- Row 1: Pipeline funnel + Response radial -->
    <div class="charts-row charts-row-3" style="margin-bottom:16px;">

      <!-- Pipeline funnel -->
      <div class="chart-card">
        <div class="chart-header">
          <div>
            <div class="chart-title">Job Hunt Pipeline</div>
            <div class="chart-sub">Your application funnel at a glance</div>
          </div>
          <span class="chart-badge"><%= stats.total %> total</span>
        </div>
        <%
          const pipeline = [
            { label:'New',       val: stats.byStatus.new       || 0, color:'#3b82f6' },
            { label:'Saved',     val: stats.byStatus.saved     || 0, color:'#8b5cf6' },
            { label:'Applied',   val: stats.byStatus.applied   || 0, color:'#f59e0b' },
            { label:'Interview', val: stats.byStatus.interview || 0, color:'#10b981' },
            { label:'Offer',     val: stats.byStatus.offer     || 0, color:'#22c55e' },
            { label:'Rejected',  val: stats.byStatus.rejected  || 0, color:'#ef4444' },
          ];
          const maxPipe = Math.max(...pipeline.map(p => p.val), 1);
        %>
        <div class="funnel-wrap">
          <% pipeline.forEach(function(p) {
            const pct = Math.round((p.val / maxPipe) * 100);
          %>
          <div class="funnel-row">
            <div class="funnel-label"><%= p.label %></div>
            <div class="funnel-track">
              <div class="funnel-fill" style="width:<%= pct %>%;background:<%= p.color %>;">
                <% if (p.val > 0) { %><%= p.val %><% } %>
              </div>
            </div>
            <div class="funnel-count"><%= p.val %></div>
          </div>
          <% }); %>
        </div>
        <% if ((stats.byStatus.applied || 0) > 0) {
          const appToInt = Math.round(((stats.byStatus.interview||0) / (stats.byStatus.applied||1)) * 100);
          const intToOff = Math.round(((stats.byStatus.offer||0) / Math.max(stats.byStatus.interview||1,1)) * 100);
        %>
        <div class="conv-row" style="margin-top:16px;">
          <span style="font-size:10px;color:var(--faint);font-weight:600;">Conversion:</span>
          <span class="conv-chip <%= appToInt > 20 ? 'good' : '' %>">Applied→Interview: <%= appToInt %>%</span>
          <span class="conv-chip <%= intToOff > 30 ? 'good' : '' %>">Interview→Offer: <%= intToOff %>%</span>
        </div>
        <% } %>
      </div>

      <!-- Response rate radial -->
      <div class="chart-card" style="display:flex;flex-direction:column;">
        <div class="chart-header">
          <div>
            <div class="chart-title">Response Rate</div>
            <div class="chart-sub">Interviews received / applied</div>
          </div>
        </div>
        <div id="chart-radial" style="flex:1;min-height:220px;"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:8px;">
          <div style="text-align:center;padding:12px;background:#f9fafb;border-radius:10px;">
            <div style="font-size:20px;font-weight:900;color:#f59e0b;"><%= stats.byStatus.applied || 0 %></div>
            <div style="font-size:9px;font-weight:700;color:var(--faint);text-transform:uppercase;letter-spacing:0.06em;margin-top:2px;">Applied</div>
          </div>
          <div style="text-align:center;padding:12px;background:#f9fafb;border-radius:10px;">
            <div style="font-size:20px;font-weight:900;color:#10b981;"><%= stats.byStatus.interview || 0 %></div>
            <div style="font-size:9px;font-weight:700;color:var(--faint);text-transform:uppercase;letter-spacing:0.06em;margin-top:2px;">Interviews</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Row 2: Status donut + Weekly comparison -->
    <div class="charts-row charts-row-2" style="margin-bottom:16px;">
      <div class="chart-card">
        <div class="chart-header">
          <div>
            <div class="chart-title">Status Breakdown</div>
            <div class="chart-sub">Distribution across all statuses</div>
          </div>
        </div>
        <div id="chart-donut" style="min-height:260px;"></div>
      </div>

      <div class="chart-card">
        <div class="chart-header">
          <div>
            <div class="chart-title">Weekly Activity</div>
            <div class="chart-sub">New jobs scraped this vs last week</div>
          </div>
          <% const weekDelta = stats.thisWeek - stats.lastWeek; %>
          <span class="chart-badge" style="background:<%= weekDelta >= 0 ? 'rgba(5,150,105,0.08)' : 'rgba(239,68,68,0.08)' %>;color:<%= weekDelta >= 0 ? '#059669' : '#ef4444' %>;">
            <%= weekDelta >= 0 ? '▲' : '▼' %> <%= Math.abs(weekDelta) %>
          </span>
        </div>
        <div id="chart-weekly" style="min-height:260px;"></div>
      </div>
    </div>

    <!-- Row 3: Top sources full width -->
    <div class="chart-card">
      <div class="chart-header">
        <div>
          <div class="chart-title">Jobs by Source</div>
          <div class="chart-sub">How many jobs scraped per platform</div>
        </div>
        <span class="chart-badge"><%= Object.keys(stats.bySource).length %> platforms</span>
      </div>
      <div id="chart-sources" style="min-height:280px;"></div>
    </div>

  </div>
</div>

<!-- Inject server data for ApexCharts -->
<script>
  const STATS        = <%- JSON.stringify(stats) %>;
  const PLAT_COLORS  = <%- JSON.stringify(platformColors) %>;
  const STAT_COLORS  = <%- JSON.stringify(statusColors) %>;

  const CHART_DEFAULTS = {
    fontFamily: "'Inter', sans-serif",
    toolbar: { show: false },
    animations: { enabled: true, easing: 'easeinout', speed: 700 },
  };

  // ── 1. Radial bar — Response Rate ──────────────────────────────
  new ApexCharts(document.getElementById('chart-radial'), {
    chart: { ...CHART_DEFAULTS, type: 'radialBar', height: 230 },
    series: [STATS.responseRate],
    labels: ['Response Rate'],
    plotOptions: {
      radialBar: {
        hollow: { size: '58%' },
        track: { background: '#f3f4f6', strokeWidth: '100%' },
        dataLabels: {
          name: { fontSize: '11px', color: '#9ca3af', offsetY: 22 },
          value: {
            fontSize: '32px', fontWeight: '900', color: '#111827', offsetY: -10,
            formatter: v => v + '%',
          },
        },
      },
    },
    fill: {
      type: 'gradient',
      gradient: { shade: 'light', type: 'horizontal', gradientToColors: ['#7c3aed'], stops: [0, 100] },
    },
    colors: ['#4f46e5'],
    stroke: { lineCap: 'round' },
  }).render();

  // ── 2. Donut — Status breakdown ────────────────────────────────
  const statusKeys    = ['new','saved','applied','interview','offer','rejected'];
  const statusLabels  = ['New','Saved','Applied','Interview','Offer','Rejected'];
  const statusSeries  = statusKeys.map(k => STATS.byStatus[k] || 0);
  const statusColors  = statusKeys.map(k => STAT_COLORS[k] || '#e5e7eb');

  new ApexCharts(document.getElementById('chart-donut'), {
    chart: { ...CHART_DEFAULTS, type: 'donut', height: 280 },
    series: statusSeries,
    labels: statusLabels,
    colors: statusColors,
    legend: { position: 'bottom', fontSize: '11px', fontWeight: 600, labels: { colors: '#6b7280' } },
    dataLabels: { enabled: true, style: { fontSize: '11px', fontWeight: 700 }, dropShadow: { enabled: false } },
    plotOptions: {
      pie: {
        donut: {
          size: '60%',
          labels: {
            show: true,
            total: {
              show: true, label: 'Total', fontSize: '11px', color: '#6b7280', fontWeight: 600,
              formatter: () => STATS.total,
            },
            value: { fontSize: '22px', fontWeight: 900, color: '#111827' },
          },
        },
      },
    },
    stroke: { width: 2, colors: ['#ffffff'] },
    tooltip: { y: { formatter: v => v + ' jobs' } },
  }).render();

  // ── 3. Weekly bar comparison ───────────────────────────────────
  new ApexCharts(document.getElementById('chart-weekly'), {
    chart: { ...CHART_DEFAULTS, type: 'bar', height: 280 },
    series: [
      { name: 'Last Week', data: [STATS.lastWeek] },
      { name: 'This Week', data: [STATS.thisWeek] },
    ],
    xaxis: { categories: ['Jobs Scraped'], labels: { style: { fontSize: '11px', fontWeight: 600, colors: '#6b7280' } } },
    yaxis: { labels: { style: { fontSize: '10px', colors: '#9ca3af' } } },
    colors: ['#d1d5db', '#4f46e5'],
    plotOptions: {
      bar: {
        columnWidth: '40%', borderRadius: 8, borderRadiusApplication: 'end',
        dataLabels: { position: 'top' },
      },
    },
    dataLabels: {
      enabled: true, offsetY: -22,
      style: { fontSize: '13px', fontWeight: 800, colors: ['#6b7280', '#4f46e5'] },
    },
    legend: { position: 'top', fontSize: '11px', fontWeight: 600, labels: { colors: '#6b7280' } },
    grid: { borderColor: '#f3f4f6', strokeDashArray: 4 },
    tooltip: { y: { formatter: v => v + ' jobs' } },
  }).render();

  // ── 4. Horizontal bar — Sources ────────────────────────────────
  const srcEntries = Object.entries(STATS.bySource)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 15);
  const srcLabels = srcEntries.map(([k]) => k.toUpperCase());
  const srcValues = srcEntries.map(([, v]) => v);
  const srcColors = srcEntries.map(([k]) => PLAT_COLORS[k] || '#6366f1');

  new ApexCharts(document.getElementById('chart-sources'), {
    chart: { ...CHART_DEFAULTS, type: 'bar', height: Math.max(280, srcLabels.length * 36) },
    series: [{ name: 'Jobs', data: srcValues }],
    xaxis: { categories: srcLabels, labels: { style: { fontSize: '10px', fontWeight: 700, colors: '#6b7280' } } },
    yaxis: { labels: { style: { fontSize: '10px', colors: '#9ca3af' } } },
    plotOptions: {
      bar: {
        horizontal: true, borderRadius: 6, borderRadiusApplication: 'end',
        barHeight: '56%',
        distributed: true,
        dataLabels: { position: 'right' },
      },
    },
    colors: srcColors,
    dataLabels: {
      enabled: true, offsetX: 6,
      style: { fontSize: '11px', fontWeight: 700, colors: ['#374151'] },
    },
    legend: { show: false },
    grid: { borderColor: '#f3f4f6', strokeDashArray: 4, xaxis: { lines: { show: true } }, yaxis: { lines: { show: false } } },
    tooltip: { y: { formatter: v => v + ' jobs' } },
  }).render();

  // ── Mobile sidebar ──────────────────────────────────────────────
  function openSidebar()  { document.getElementById('sidebar').classList.add('open');  document.getElementById('overlay').classList.add('open');  }
  function closeSidebar() { document.getElementById('sidebar').classList.remove('open'); document.getElementById('overlay').classList.remove('open'); }
</script>
</body>
</html>
